{
	"name": "main",
	"image": "nwreadinglist:main",
	"initializeCommand": "docker build -f .devcontainer/main/Dockerfile -t nwreadinglist:main .",
	"runArgs": ["--name", "nwreadinglist-main"],
	"containerEnv": {
		"TZ": "Europe/Stockholm",
		"DEVCONTAINER_NAME": "main"
	},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"ms-toolsai.datawrangler",
				"shd101wyy.markdown-preview-enhanced"
			]
		}
	},
	"mounts": [
			"source=${localEnv:USERPROFILE}/Desktop/nwreadinglist/,target=/home/nwreadinglist/,type=bind,consistency=cached"
	]
}